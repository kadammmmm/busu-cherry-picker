# ==============================================================================
# Cherry Picker Widget - Environment Configuration
# ==============================================================================
# Copy this file to .env and update values for your environment

# Server Configuration
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# Host URI - The public URL where this server is accessible
# Used for loading widget bundle and establishing WebSocket connections
# Examples:
#   Local development: http://localhost:5000
#   Production: https://cherry-picker.yourcompany.com
HOST_URI=http://localhost:5000

# CORS Configuration
# ------------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Must include all Webex CC desktop regions you support
CORS_ORIGINS=https://desktop.wxcc-us1.cisco.com,https://desktop.wxcc-eu1.cisco.com,https://desktop.wxcc-eu2.cisco.com,https://desktop.wxcc-anz1.cisco.com,https://desktop.wxcc-ca1.cisco.com,https://desktop.wxcc-jp1.cisco.com,https://desktop.wxcc-sg1.cisco.com

# Cache Configuration
# ------------------------------------------------------------------------------
# Time-to-live for cached caller ID data (in seconds)
# Default: 3600 (1 hour)
CACHE_TTL=3600

# Logging Configuration
# ------------------------------------------------------------------------------
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Redis Configuration (Optional - for distributed deployments)
# ------------------------------------------------------------------------------
# Uncomment to enable Redis-backed session storage
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# SSL Configuration (Optional - if not using reverse proxy)
# ------------------------------------------------------------------------------
# SSL_ENABLED=false
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt
